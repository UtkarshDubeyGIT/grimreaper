# DigitalOcean runner environment. On the VM, install this as:
# /etc/grimreaper/runner.env

# Required: public Convex deployment URL.
CONVEX_URL=https://your-deployment.convex.cloud

# Required: generate with `openssl rand -hex 32`.
# This exact value must also be set in the Convex hosted environment.
CONVEX_RUNNER_TOKEN=replace-with-a-long-random-token

# Required for Hermes/AI scans. Create this in the OpenAI API dashboard.
OPENAI_API_KEY=

# Optional providers. Leave blank when their corresponding *_ENABLED flag is false.
LINKUP_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Runner behavior. These defaults are suitable for the first deployment.
ARTIFACT_STORAGE_PROVIDER=local
RUNNER_ID=grimreaper-do-1
RUNNER_CONCURRENCY=2
RUNNER_HEARTBEAT_INTERVAL_MS=10000
RUNNER_POLL_INTERVAL_MS=2500
FREE_SCAN_TIMEOUT_SECONDS=90

HERMES_ENABLED=true
LINKUP_ENABLED=false
ELEVENLABS_ENABLED=false
DODO_ENABLED=false
