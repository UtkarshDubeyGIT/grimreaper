# Browser frontend configuration. Copy this file to .env.local.
# VITE_* values are bundled into browser code and MUST NOT contain secrets.

# Added automatically by `npx convex dev`; do not invent this value.
# CONVEX_DEPLOYMENT=dev:your-deployment-name

# Public URL shown by `npx convex dev` or in the Convex dashboard.
# Leave blank to run the frontend with built-in demo data.
VITE_CONVEX_URL=

# Public Cloudflare Worker URL, without a trailing slash.
# Example: https://grimreaper-edge.your-account.workers.dev
VITE_EDGE_API_BASE=
